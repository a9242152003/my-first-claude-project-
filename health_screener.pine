//@version=5
// 多標的健康篩選表(大版,三欄)— Claude
// 五大類預填:加密前10 / 美股大盤 / 美股前10 / 台股0050 / 台股前10
// 燈號=市場體質(波動度百分位為主):🟢有燃料 🟡普通 🔴枯竭(可能變性)。趨勢=多↑/空↓/盤—
// ⚠️ 這是「指標」(建立時選指標)。算的是「市場體質/領先警報」,不是每標的的回測PF。
indicator("多標的健康篩選表(大版)— Claude", overlay=true)

volLB = input.int(500, "波動度百分位回看(根)", group="設定")
volG  = input.float(40, "🟢 健康門檻 %", group="設定")
volR  = input.float(20, "🔴 枯竭門檻 %", group="設定")
tszI  = input.string("正常","字體大小", options=["小","正常","大"], group="設定")
posI  = input.string("右上","表格位置", options=["右上","右下","左上","左下"], group="設定")
ts = tszI=="小"?size.small : tszI=="大"?size.large : size.normal

// ── 加密前10 ──
c1=input.symbol("BYBIT:BTCUSDT.P","加密1",group="加密前10")
c2=input.symbol("BYBIT:ETHUSDT.P","加密2",group="加密前10")
c3=input.symbol("BYBIT:BNBUSDT.P","加密3",group="加密前10")
c4=input.symbol("BYBIT:SOLUSDT.P","加密4",group="加密前10")
c5=input.symbol("BYBIT:XRPUSDT.P","加密5",group="加密前10")
c6=input.symbol("BYBIT:ADAUSDT.P","加密6",group="加密前10")
c7=input.symbol("BYBIT:DOGEUSDT.P","加密7",group="加密前10")
c8=input.symbol("BYBIT:AVAXUSDT.P","加密8",group="加密前10")
c9=input.symbol("BYBIT:TRXUSDT.P","加密9",group="加密前10")
c10=input.symbol("BYBIT:LINKUSDT.P","加密10",group="加密前10")
// ── 美股大盤 + 前10 ──
u1=input.symbol("SP:SPX","美盤1 S&P500",group="美股")
u2=input.symbol("NASDAQ:IXIC","美盤2 那指",group="美股")
u3=input.symbol("NASDAQ:NVDA","美股1",group="美股")
u4=input.symbol("NASDAQ:TSLA","美股2",group="美股")
u5=input.symbol("NASDAQ:AAPL","美股3",group="美股")
u6=input.symbol("NASDAQ:MSFT","美股4",group="美股")
u7=input.symbol("NASDAQ:AMZN","美股5",group="美股")
u8=input.symbol("NASDAQ:META","美股6",group="美股")
u9=input.symbol("NASDAQ:GOOGL","美股7",group="美股")
u10=input.symbol("NASDAQ:AMD","美股8",group="美股")
u11=input.symbol("NASDAQ:AVGO","美股9",group="美股")
u12=input.symbol("NASDAQ:NFLX","美股10",group="美股")
// ── 台股大盤/0050 + 前10 ──
t1=input.symbol("TWSE:0050","台盤 0050",group="台股")
t2=input.symbol("TWSE:2330","台股1 台積電",group="台股")
t3=input.symbol("TWSE:2317","台股2 鴻海",group="台股")
t4=input.symbol("TWSE:2454","台股3 聯發科",group="台股")
t5=input.symbol("TWSE:2308","台股4 台達電",group="台股")
t6=input.symbol("TWSE:2382","台股5 廣達",group="台股")
t7=input.symbol("TWSE:2891","台股6 中信金",group="台股")
t8=input.symbol("TWSE:2412","台股7 中華電",group="台股")
t9=input.symbol("TWSE:2881","台股8 富邦金",group="台股")
t10=input.symbol("TWSE:3711","台股9 日月光",group="台股")
t11=input.symbol("TWSE:2603","台股10 長榮",group="台股")

f_h(sym) =>
    request.security(sym, timeframe.period, [ta.percentrank(ta.atr(14)/close, volLB), ta.ema(close,200) > ta.ema(close,200)[20] ? 1 : ta.ema(close,200) < ta.ema(close,200)[20] ? -1 : 0, close > ta.ema(close,200) ? 1 : -1], ignore_invalid_symbol=true)

[vc1,pc1,ac1]=f_h(c1)
[vc2,pc2,ac2]=f_h(c2)
[vc3,pc3,ac3]=f_h(c3)
[vc4,pc4,ac4]=f_h(c4)
[vc5,pc5,ac5]=f_h(c5)
[vc6,pc6,ac6]=f_h(c6)
[vc7,pc7,ac7]=f_h(c7)
[vc8,pc8,ac8]=f_h(c8)
[vc9,pc9,ac9]=f_h(c9)
[vc10,pc10,ac10]=f_h(c10)
[vu1,pu1,au1]=f_h(u1)
[vu2,pu2,au2]=f_h(u2)
[vu3,pu3,au3]=f_h(u3)
[vu4,pu4,au4]=f_h(u4)
[vu5,pu5,au5]=f_h(u5)
[vu6,pu6,au6]=f_h(u6)
[vu7,pu7,au7]=f_h(u7)
[vu8,pu8,au8]=f_h(u8)
[vu9,pu9,au9]=f_h(u9)
[vu10,pu10,au10]=f_h(u10)
[vu11,pu11,au11]=f_h(u11)
[vu12,pu12,au12]=f_h(u12)
[vt1,pt1,at1]=f_h(t1)
[vt2,pt2,at2]=f_h(t2)
[vt3,pt3,at3]=f_h(t3)
[vt4,pt4,at4]=f_h(t4)
[vt5,pt5,at5]=f_h(t5)
[vt6,pt6,at6]=f_h(t6)
[vt7,pt7,at7]=f_h(t7)
[vt8,pt8,at8]=f_h(t8)
[vt9,pt9,at9]=f_h(t9)
[vt10,pt10,at10]=f_h(t10)
[vt11,pt11,at11]=f_h(t11)

tpos = posI=="右上"?position.top_right : posI=="右下"?position.bottom_right : posI=="左上"?position.top_left : position.bottom_left
var table tb = table.new(tpos, 12, 15, border_width=1)

f_cell(col, r, name, v, sl, ab) =>
    lampW = na(v) ? "—" : v<volR ? "🔴" : v<volG ? "🟡" : "🟢"
    lampC = na(v) ? color.new(color.gray,50) : v<volR ? color.new(color.red,0) : v<volG ? color.new(color.orange,0) : color.new(color.green,0)
    trd   = na(v) ? "—" : (sl>0 and ab>0 ? "多↑" : sl<0 and ab<0 ? "空↓" : "盤—")
    table.cell(tb,col,r,name,text_color=color.white,bgcolor=color.new(color.gray,15),text_size=ts,text_halign=text.align_left)
    table.cell(tb,col+1,r,lampW,text_color=color.white,bgcolor=lampC,text_size=ts)
    table.cell(tb,col+2,r,na(v)?"—":str.tostring(v,"#")+"%",text_color=color.white,bgcolor=color.new(color.gray,30),text_size=ts)
    table.cell(tb,col+3,r,trd,text_color=color.white,bgcolor=color.new(color.gray,30),text_size=ts)

f_hdr(col, r, title) =>
    table.cell(tb,col,r,title,text_color=color.white,bgcolor=color.new(color.purple,0),text_size=ts,text_halign=text.align_left)
    table.cell(tb,col+1,r,"",bgcolor=color.new(color.purple,0))
    table.cell(tb,col+2,r,"",bgcolor=color.new(color.purple,0))
    table.cell(tb,col+3,r,"",bgcolor=color.new(color.purple,0))

if barstate.islast
    f_hdr(0,0,"加密前10")
    f_hdr(4,0,"美股大盤+前10")
    f_hdr(8,0,"台股 0050+前10")
    f_cell(0,1,c1,vc1,pc1,ac1)
    f_cell(0,2,c2,vc2,pc2,ac2)
    f_cell(0,3,c3,vc3,pc3,ac3)
    f_cell(0,4,c4,vc4,pc4,ac4)
    f_cell(0,5,c5,vc5,pc5,ac5)
    f_cell(0,6,c6,vc6,pc6,ac6)
    f_cell(0,7,c7,vc7,pc7,ac7)
    f_cell(0,8,c8,vc8,pc8,ac8)
    f_cell(0,9,c9,vc9,pc9,ac9)
    f_cell(0,10,c10,vc10,pc10,ac10)
    f_cell(4,1,u1,vu1,pu1,au1)
    f_cell(4,2,u2,vu2,pu2,au2)
    f_cell(4,3,u3,vu3,pu3,au3)
    f_cell(4,4,u4,vu4,pu4,au4)
    f_cell(4,5,u5,vu5,pu5,au5)
    f_cell(4,6,u6,vu6,pu6,au6)
    f_cell(4,7,u7,vu7,pu7,au7)
    f_cell(4,8,u8,vu8,pu8,au8)
    f_cell(4,9,u9,vu9,pu9,au9)
    f_cell(4,10,u10,vu10,pu10,au10)
    f_cell(4,11,u11,vu11,pu11,au11)
    f_cell(4,12,u12,vu12,pu12,au12)
    f_cell(8,1,t1,vt1,pt1,at1)
    f_cell(8,2,t2,vt2,pt2,at2)
    f_cell(8,3,t3,vt3,pt3,at3)
    f_cell(8,4,t4,vt4,pt4,at4)
    f_cell(8,5,t5,vt5,pt5,at5)
    f_cell(8,6,t6,vt6,pt6,at6)
    f_cell(8,7,t7,vt7,pt7,at7)
    f_cell(8,8,t8,vt8,pt8,at8)
    f_cell(8,9,t9,vt9,pt9,at9)
    f_cell(8,10,t10,vt10,pt10,at10)
    f_cell(8,11,t11,vt11,pt11,at11)
