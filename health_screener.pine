//@version=5
// 多標的健康篩選表 — Claude
// 一次掃多個標的,各亮一個燈(綠/黃/紅),判斷「現在還適不適合放量突破策略」。
// 燈號依據 = 市場體質(波動度百分位為主 + 趨勢狀態),這是「標的變性」的領先訊號。
// ⚠️ 這是「指標」,不是策略。它算不出每標的的回測PF/回撤(那要把策略掛到各別圖上)。
indicator("多標的健康篩選表 — Claude", overlay=true)

volLB = input.int(500, "波動度百分位回看(根)", group="設定")
volG  = input.float(40, "🟢 波動健康門檻 %",    group="設定")
volR  = input.float(20, "🔴 波動枯竭門檻 %",    group="設定")
pos   = input.string("右上", "表格位置", options=["右上","右下","左上","左下"], group="設定")

g="標的(留空=略過)"
s01=input.symbol("BYBIT:BTCUSDT.P","#1",group=g)
s02=input.symbol("BYBIT:ETHUSDT.P","#2",group=g)
s03=input.symbol("BYBIT:SOLUSDT.P","#3",group=g)
s04=input.symbol("BYBIT:BNBUSDT.P","#4",group=g)
s05=input.symbol("BINANCE:AVAXUSDT","#5",group=g)
s06=input.symbol("NASDAQ:NVDA","#6",group=g)
s07=input.symbol("TWSE:0050","#7",group=g)
s08=input.symbol("BINANCE:ADAUSDT","#8",group=g)
s09=input.symbol("","#9",group=g)
s10=input.symbol("","#10",group=g)
s11=input.symbol("","#11",group=g)
s12=input.symbol("","#12",group=g)

f_h(sym) =>
    request.security(sym, timeframe.period, [ta.percentrank(ta.atr(14)/close, volLB), ta.ema(close,200) > ta.ema(close,200)[20] ? 1 : ta.ema(close,200) < ta.ema(close,200)[20] ? -1 : 0, close > ta.ema(close,200) ? 1 : -1], ignore_invalid_symbol=true)

[v01,p01,a01]=f_h(s01)
[v02,p02,a02]=f_h(s02)
[v03,p03,a03]=f_h(s03)
[v04,p04,a04]=f_h(s04)
[v05,p05,a05]=f_h(s05)
[v06,p06,a06]=f_h(s06)
[v07,p07,a07]=f_h(s07)
[v08,p08,a08]=f_h(s08)
[v09,p09,a09]=f_h(s09)
[v10,p10,a10]=f_h(s10)
[v11,p11,a11]=f_h(s11)
[v12,p12,a12]=f_h(s12)

tpos = pos=="右上"?position.top_right : pos=="右下"?position.bottom_right : pos=="左上"?position.top_left : position.bottom_left
var table t = table.new(tpos, 4, 13, border_width=1)

f_row(r, name, v, sl, ab) =>
    if name != ""
        lampW = na(v) ? "—" : v<volR ? "🔴" : v<volG ? "🟡" : "🟢"
        lampC = na(v) ? color.new(color.gray,50) : v<volR ? color.new(color.red,0) : v<volG ? color.new(color.orange,0) : color.new(color.green,0)
        trd   = na(v) ? "—" : (sl>0 and ab>0 ? "多↑" : sl<0 and ab<0 ? "空↓" : "盤—")
        table.cell(t,0,r,name,text_color=color.white,bgcolor=color.new(color.gray,15),text_size=size.small)
        table.cell(t,1,r,lampW,text_color=color.white,bgcolor=lampC,text_size=size.normal)
        table.cell(t,2,r,na(v)?"—":str.tostring(v,"#")+"%",text_color=color.white,bgcolor=color.new(color.gray,30),text_size=size.small)
        table.cell(t,3,r,trd,text_color=color.white,bgcolor=color.new(color.gray,30),text_size=size.small)

if barstate.islast
    table.cell(t,0,0,"標的",text_color=color.white,bgcolor=color.new(color.blue,0),text_size=size.small)
    table.cell(t,1,0,"燈",  text_color=color.white,bgcolor=color.new(color.blue,0),text_size=size.small)
    table.cell(t,2,0,"波動%",text_color=color.white,bgcolor=color.new(color.blue,0),text_size=size.small)
    table.cell(t,3,0,"趨勢", text_color=color.white,bgcolor=color.new(color.blue,0),text_size=size.small)
    f_row(1, s01,v01,p01,a01)
    f_row(2, s02,v02,p02,a02)
    f_row(3, s03,v03,p03,a03)
    f_row(4, s04,v04,p04,a04)
    f_row(5, s05,v05,p05,a05)
    f_row(6, s06,v06,p06,a06)
    f_row(7, s07,v07,p07,a07)
    f_row(8, s08,v08,p08,a08)
    f_row(9, s09,v09,p09,a09)
    f_row(10,s10,v10,p10,a10)
    f_row(11,s11,v11,p11,a11)
    f_row(12,s12,v12,p12,a12)
