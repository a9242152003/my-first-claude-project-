//@version=5
strategy("放量突破 v5 · 風險定額 · 多空 · 量價牛熊濾網 — Claude", overlay=true, initial_capital=1000000, default_qty_type=strategy.fixed, commission_type=strategy.commission.percent, commission_value=0.055, pyramiding=0, process_orders_on_close=true, calc_on_every_tick=false, max_labels_count=500)

// ═══ 進場參數 ═══
boxLen   = input.int(10,    "突破箱長度",       group="進場")
rvolLen  = input.int(20,    "量能均長",         group="進場")
rvolMin  = input.float(1.3, "放量門檻 RVOL",    group="進場", step=0.1)
emaLen   = input.int(200,   "趨勢 EMA",         group="進場")
atrLen   = input.int(14,    "ATR 長度",         group="進場")
atrBuf   = input.float(0.25,"突破緩衝 ×ATR",    group="進場", step=0.05)
atrTrail = input.float(3.5, "移動停利 ×ATR",    group="出場", step=0.5)

// ═══ 部位(風險定額,槓桿是結果不是輸入)═══
riskPct  = input.float(5.0, "每筆風險 %（當前權益）", group="部位", step=0.5)
levCap   = input.float(5.0, "最大槓桿上限",          group="部位", step=0.5)
minStopP = input.float(0.5, "最小停損距離 %",        group="部位", step=0.1) / 100.0

// ═══ 方向 + 牛熊濾網 ═══
useLong  = input.bool(true,  "做多", group="方向")
useShort = input.bool(true,  "做空", group="方向")
shortReg = input.string("EMA200下彎", "做空濾網（牛市不做空）", options=["不濾(照舊)","EMA50<EMA200","EMA100<EMA200","EMA200下彎"], group="方向")

// ═══ 保本 ═══
beMode   = input.string("漲N個ATR後拉到成本", "保本", options=["關閉","漲N個ATR後拉到成本"], group="出場")
beATR    = input.float(3.0, "保本觸發 ×ATR", group="出場", step=0.5)

// ═══ 標示(開倉價 / 止損 / 開倉價值 / 可選固定止盈)═══
showLabel = input.bool(true,  "進場標示 開倉價·止損·開倉價值$", group="標示")
showTP    = input.bool(false, "顯示固定止盈線（R倍數,趨勢策略預設關)", group="標示", tooltip="本策略原生用移動停損出場,沒有固定止盈。打開只是畫參考靶;設死靶會砍掉大單、降低報酬。")
tpR       = input.float(3.0,  "固定止盈 = N 倍風險(R)", group="標示", step=0.5)

// ═══ 指標 ═══
atr   = ta.atr(atrLen)
rvol  = volume / ta.sma(volume, rvolLen)
ema   = ta.ema(close, emaLen)
e50   = ta.ema(close, 50)
e100  = ta.ema(close, 100)
boxHi = ta.highest(high, boxLen)[1]
boxLo = ta.lowest(low,  boxLen)[1]
isV   = rvol >= rvolMin

// ═══ 牛熊濾網(純量價,可套用任何幣種)═══
bearReg = shortReg == "EMA50<EMA200" ? e50 < ema : shortReg == "EMA100<EMA200" ? e100 < ema : shortReg == "EMA200下彎" ? ema < ema[20] : true

longSig  = useLong  and close > boxHi + atrBuf * atr and isV and close > ema
shortSig = useShort and bearReg and close < boxLo - atrBuf * atr and isV and close < ema

// ═══ 狀態(跨K棒保存)═══
var float entryPx  = na
var float pStop    = na
var float initStop = na   // 初始止損(進場當下,固定不動,給標示用)
var float tpPx     = na   // 固定止盈參考價
var float notion   = na   // 開倉價值(美金)
var float atrE     = na
var float hh       = na
var float ll       = na
var bool  beArm    = false

// ═══ 進場部位大小:倉位 =(風險% × 權益)÷ 停損距離,封頂 levCap ═══
longDist  = math.max((close - low[1]) / close, minStopP)
shortDist = math.max((high[1] - close) / close, minStopP)
longQty   = math.min(strategy.equity * riskPct / 100.0 / (longDist  * close), levCap * strategy.equity / close)
shortQty  = math.min(strategy.equity * riskPct / 100.0 / (shortDist * close), levCap * strategy.equity / close)

// ═══ 進場(只在空手時)═══
if strategy.position_size == 0
    if longSig
        strategy.entry("多", strategy.long, qty=longQty)
        entryPx  := close
        pStop    := close - longDist * close
        initStop := pStop
        tpPx     := close + tpR * (close - pStop)          // 多:進場 + N×風險
        notion   := longQty * close
        atrE     := atr
        hh       := high
        beArm    := false
        if showLabel
            label.new(bar_index, low, text="▲多 " + str.tostring(close, format.mintick) + "\n損 " + str.tostring(initStop, format.mintick) + (showTP ? "\n盈 " + str.tostring(tpPx, format.mintick) : "") + "\n值 $" + str.tostring(notion, "#,###") + "\n槓 " + str.tostring(notion / strategy.equity, "#.0") + "x", yloc=yloc.belowbar, style=label.style_label_up, color=color.new(color.green, 15), textcolor=color.white, size=size.small)
    else if shortSig
        strategy.entry("空", strategy.short, qty=shortQty)
        entryPx  := close
        pStop    := close + shortDist * close
        initStop := pStop
        tpPx     := close - tpR * (pStop - close)          // 空:進場 − N×風險
        notion   := shortQty * close
        atrE     := atr
        ll       := low
        beArm    := false
        if showLabel
            label.new(bar_index, high, text="▼空 " + str.tostring(close, format.mintick) + "\n損 " + str.tostring(initStop, format.mintick) + (showTP ? "\n盈 " + str.tostring(tpPx, format.mintick) : "") + "\n值 $" + str.tostring(notion, "#,###") + "\n槓 " + str.tostring(notion / strategy.equity, "#.0") + "x", yloc=yloc.abovebar, style=label.style_label_down, color=color.new(color.red, 15), textcolor=color.white, size=size.small)

// ═══ 多單管理:吊燈移動停利 +(可選)保本 ═══
if strategy.position_size > 0
    hh := math.max(hh, high)
    if beMode == "漲N個ATR後拉到成本" and not beArm and hh >= entryPx + beATR * atrE
        beArm := true
    pStop := math.max(nz(pStop, hh - atrTrail * atr), hh - atrTrail * atr)
    if beArm
        pStop := math.max(pStop, entryPx)
    strategy.exit("多出", "多", stop=pStop)

// ═══ 空單管理 ═══
if strategy.position_size < 0
    ll := math.min(ll, low)
    if beMode == "漲N個ATR後拉到成本" and not beArm and ll <= entryPx - beATR * atrE
        beArm := true
    pStop := math.min(nz(pStop, ll + atrTrail * atr), ll + atrTrail * atr)
    if beArm
        pStop := math.min(pStop, entryPx)
    strategy.exit("空出", "空", stop=pStop)

// ═══ 視覺化 ═══
plot(ema, "EMA200", color.new(color.orange, 0))
plot(e50, "EMA50",  color.new(color.aqua, 55))
bgcolor(bearReg ? color.new(color.red, 92) : na, title="可做空區（熊）")
plot(strategy.position_size != 0 ? entryPx : na, "開倉價",        color.new(color.gray, 0),     style=plot.style_linebr, linewidth=1)
plot(strategy.position_size != 0 ? pStop   : na, "止損/移動止盈", color.new(color.fuchsia, 0),  style=plot.style_linebr, linewidth=2)
plot(strategy.position_size != 0 and showTP ? tpPx : na, "固定止盈", color.new(color.lime, 0),  style=plot.style_linebr, linewidth=1)
// 開倉價值 / 槓桿(資料視窗,可對照手動下單)
plot(strategy.position_size != 0 ? notion : na, "開倉價值$", display=display.data_window)
plot(strategy.position_size != 0 ? notion / strategy.equity : na, "進場槓桿x", display=display.data_window)
