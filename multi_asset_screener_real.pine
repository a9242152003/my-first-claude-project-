//@version=5
// 多標的「近半年 vs 歷史」綠燈總表(30 檔)— Claude
// 掛在 BTC 日線圖。每檔用同一套寫死規則跑全歷史(2017起算),
// 衰退判定 = 把「最近半年的權益報酬」拿去跟「歷史上所有半年區間的報酬」排名(百分位)。
//   排名掉到最差段 → 這半年是史上數一數二爛 → 衰退,轉黃/紅。半年就反應,不用等一年。
// 綠燈 = 歷史夠強(PF≥1.5、回撤≤60%) 且 近半年沒掉到歷史爛段。
//
// ⚠️ 很重:30 檔 = 跑 30 次回測,可能轉很久。卡住就把某類 10 格留白分批跑。
// ⚠️ 表固定掛 BTC 圖(24小時、不會把幣的週末K切壞)。燈=能不能做,不是叫你立刻進場。
indicator("近半年vs歷史 綠燈總表(30檔)— Claude", overlay=true)

boxLen   = 10
rvolLen  = 20
rvolMin  = 1.3
emaLen   = 200
atrLen   = 14
atrBuf   = 0.25
atrTrail = 3.5
riskPct  = 5.0
levCap   = 5.0
minStopP = 0.005
beATR    = 3.0
COMM     = 0.00055
INIT     = 1000000.0

startY  = input.int(2017, "起算年（只看這年以後）", group="判準")
minTr   = input.int(20,   "全期最低交易數",       group="判準")
minPF   = input.float(1.3,"全期最低 PF",          group="判準")
minRDD  = input.float(3.0,"全期最低 報酬/回撤",   group="判準")
ddCap   = input.float(60, "綠燈：最大回撤上限 %",  group="綠燈品質")
pfGreen = input.float(1.5,"綠燈：最低 PF",          group="綠燈品質")
halfLen = input.int(126,  "近期窗口（交易日，126≈半年）", group="近半年vs歷史")
histLen = input.int(2520, "歷史比較回看（交易日，2520≈10年）", group="近半年vs歷史")
freshMin= input.float(30, "綠燈：近半年報酬排名需≥（百分位）", group="近半年vs歷史")
redPct  = input.float(15, "紅燈：近半年報酬排名低於（百分位）=衰退", group="近半年vs歷史")
greenOnly = input.bool(true, "只顯示綠燈(關掉=全部都顯示)", group="顯示")
posI   = input.string("右上","表格位置", options=["右上","右下","左上","左下","中央"], group="顯示")
tpos = posI=="右下"?position.bottom_right : posI=="左上"?position.top_left : posI=="左下"?position.bottom_left : posI=="中央"?position.middle_center : position.top_right
startTime = timestamp(startY, 1, 1, 0, 0)

gc = "加密前10大"
s1  = input.symbol("BINANCE:BTCUSDT",  "幣1",  group=gc)
s2  = input.symbol("BINANCE:ETHUSDT",  "幣2",  group=gc)
s3  = input.symbol("BINANCE:BNBUSDT",  "幣3",  group=gc)
s4  = input.symbol("BINANCE:SOLUSDT",  "幣4",  group=gc)
s5  = input.symbol("BINANCE:XRPUSDT",  "幣5",  group=gc)
s6  = input.symbol("BINANCE:ADAUSDT",  "幣6",  group=gc)
s7  = input.symbol("BINANCE:DOGEUSDT", "幣7",  group=gc)
s8  = input.symbol("BINANCE:AVAXUSDT", "幣8",  group=gc)
s9  = input.symbol("BINANCE:TRXUSDT",  "幣9",  group=gc)
s10 = input.symbol("BINANCE:LINKUSDT", "幣10", group=gc)
gu = "美股前10大"
s11 = input.symbol("NASDAQ:NVDA",  "美1",  group=gu)
s12 = input.symbol("NASDAQ:AAPL",  "美2",  group=gu)
s13 = input.symbol("NASDAQ:MSFT",  "美3",  group=gu)
s14 = input.symbol("NASDAQ:AMZN",  "美4",  group=gu)
s15 = input.symbol("NASDAQ:GOOGL", "美5",  group=gu)
s16 = input.symbol("NASDAQ:META",  "美6",  group=gu)
s17 = input.symbol("NASDAQ:TSLA",  "美7",  group=gu)
s18 = input.symbol("NASDAQ:AVGO",  "美8",  group=gu)
s19 = input.symbol("NASDAQ:AMD",   "美9",  group=gu)
s20 = input.symbol("NASDAQ:NFLX",  "美10", group=gu)
gt = "台股前10大"
s21 = input.symbol("TWSE:2330", "台1",  group=gt)
s22 = input.symbol("TWSE:2317", "台2",  group=gt)
s23 = input.symbol("TWSE:2454", "台3",  group=gt)
s24 = input.symbol("TWSE:2308", "台4",  group=gt)
s25 = input.symbol("TWSE:2382", "台5",  group=gt)
s26 = input.symbol("TWSE:2891", "台6",  group=gt)
s27 = input.symbol("TWSE:2412", "台7",  group=gt)
s28 = input.symbol("TWSE:2881", "台8",  group=gt)
s29 = input.symbol("TWSE:3711", "台9",  group=gt)
s30 = input.symbol("TWSE:2603", "台10", group=gt)

// ── 引擎:回傳 [報酬%, 回撤%, 全PF, 全筆, 近半年報酬%, 近半年排名(百分位), 現在多空] ──
f_eval() =>
    ema200 = ta.ema(close, emaLen)
    atr    = ta.atr(atrLen)
    vsma   = ta.sma(volume, rvolLen)
    rvol   = vsma > 0 ? volume / vsma : 0.0
    hh10   = ta.highest(high, boxLen)[1]
    ll10   = ta.lowest(low,  boxLen)[1]
    var float cash  = INIT
    var int   pos   = 0
    var float qty   = 0.0
    var float entry = 0.0
    var float pst   = 0.0
    var float atrE  = 0.0
    var float hh    = 0.0
    var float ll    = 0.0
    var bool  beArm = false
    var float peak  = INIT
    var float maxdd = 0.0
    var float gpAll = 0.0
    var float glAll = 0.0
    var int   nAll  = 0
    if pos != 0 and not na(atr)
        float ex = na
        if pos > 0
            if low <= pst
                ex := open < pst ? open : pst
        else
            if high >= pst
                ex := open > pst ? open : pst
        if not na(ex)
            float pnl = pos > 0 ? (ex - entry) * qty : (entry - ex) * qty
            pnl := pnl - COMM * qty * (entry + ex)
            cash := cash + pnl
            nAll  := nAll + 1
            gpAll := gpAll + (pnl > 0 ? pnl : 0.0)
            glAll := glAll + (pnl < 0 ? -pnl : 0.0)
            pos := 0
        else
            if pos > 0
                hh := math.max(hh, high)
                if not beArm and hh >= entry + beATR * atrE
                    beArm := true
                pst := math.max(pst, hh - atrTrail * atr)
                if beArm
                    pst := math.max(pst, entry)
            else
                ll := math.min(ll, low)
                if not beArm and ll <= entry - beATR * atrE
                    beArm := true
                pst := math.min(pst, ll + atrTrail * atr)
                if beArm
                    pst := math.min(pst, entry)
    bool canTrade = pos == 0 and time >= startTime and bar_index > emaLen and not na(atr) and not na(ema200[20]) and not na(hh10)
    if canTrade
        bool bear   = ema200 < ema200[20]
        bool longS  = close > hh10 + atrBuf * atr and rvol >= rvolMin and close > ema200
        bool shortS = bear and close < ll10 - atrBuf * atr and rvol >= rvolMin and close < ema200
        if longS
            float d = math.max((close - low[1]) / close, minStopP)
            qty   := math.min(cash * riskPct / 100.0 / (d * close), levCap * cash / close)
            pos   := 1
            entry := close
            pst   := close - d * close
            atrE  := atr
            hh    := high
            beArm := false
        else if shortS
            float d = math.max((high[1] - close) / close, minStopP)
            qty   := math.min(cash * riskPct / 100.0 / (d * close), levCap * cash / close)
            pos   := -1
            entry := close
            pst   := close + d * close
            atrE  := atr
            ll    := low
            beArm := false
    float eq = cash + (pos == 0 ? 0.0 : pos > 0 ? (close - entry) * qty : (entry - close) * qty)
    peak  := math.max(peak, eq)
    maxdd := math.max(maxdd, (peak - eq) / peak * 100.0)
    float netP   = (eq - INIT) / INIT * 100.0
    float pfFull = glAll > 0 ? gpAll / glAll : (gpAll > 0 ? 99.0 : 0.0)
    // 近半年報酬 vs 歷史排名
    float recRet = (bar_index > halfLen and eq[halfLen] != 0) ? (eq - eq[halfLen]) / eq[halfLen] * 100.0 : na
    float recPct = ta.percentrank(recRet, histLen)
    int regn = na(ema200) or na(ema200[20]) ? 0 : (ema200 > ema200[20] and close > ema200 ? 1 : (ema200 < ema200[20] and close < ema200 ? -1 : 0))
    [netP, maxdd, pfFull, nAll, recRet, recPct, regn]

f_req(sym) =>
    request.security(sym, "1D", f_eval(), gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)

[n1,d1,f1,nf1,rr1,rp1,r1]    = f_req(s1)
[n2,d2,f2,nf2,rr2,rp2,r2]    = f_req(s2)
[n3,d3,f3,nf3,rr3,rp3,r3]    = f_req(s3)
[n4,d4,f4,nf4,rr4,rp4,r4]    = f_req(s4)
[n5,d5,f5,nf5,rr5,rp5,r5]    = f_req(s5)
[n6,d6,f6,nf6,rr6,rp6,r6]    = f_req(s6)
[n7,d7,f7,nf7,rr7,rp7,r7]    = f_req(s7)
[n8,d8,f8,nf8,rr8,rp8,r8]    = f_req(s8)
[n9,d9,f9,nf9,rr9,rp9,r9]    = f_req(s9)
[n10,d10,f10,nf10,rr10,rp10,r10] = f_req(s10)
[n11,d11,f11,nf11,rr11,rp11,r11] = f_req(s11)
[n12,d12,f12,nf12,rr12,rp12,r12] = f_req(s12)
[n13,d13,f13,nf13,rr13,rp13,r13] = f_req(s13)
[n14,d14,f14,nf14,rr14,rp14,r14] = f_req(s14)
[n15,d15,f15,nf15,rr15,rp15,r15] = f_req(s15)
[n16,d16,f16,nf16,rr16,rp16,r16] = f_req(s16)
[n17,d17,f17,nf17,rr17,rp17,r17] = f_req(s17)
[n18,d18,f18,nf18,rr18,rp18,r18] = f_req(s18)
[n19,d19,f19,nf19,rr19,rp19,r19] = f_req(s19)
[n20,d20,f20,nf20,rr20,rp20,r20] = f_req(s20)
[n21,d21,f21,nf21,rr21,rp21,r21] = f_req(s21)
[n22,d22,f22,nf22,rr22,rp22,r22] = f_req(s22)
[n23,d23,f23,nf23,rr23,rp23,r23] = f_req(s23)
[n24,d24,f24,nf24,rr24,rp24,r24] = f_req(s24)
[n25,d25,f25,nf25,rr25,rp25,r25] = f_req(s25)
[n26,d26,f26,nf26,rr26,rp26,r26] = f_req(s26)
[n27,d27,f27,nf27,rr27,rp27,r27] = f_req(s27)
[n28,d28,f28,nf28,rr28,rp28,r28] = f_req(s28)
[n29,d29,f29,nf29,rr29,rp29,r29] = f_req(s29)
[n30,d30,f30,nf30,rr30,rp30,r30] = f_req(s30)

var table tb = table.new(tpos, 6, 33, border_width=1, frame_width=1, frame_color=color.gray)
gC = color.new(color.green, 0)
yC = color.new(color.orange, 0)
rC = color.new(color.red, 0)
kC = color.new(color.gray, 20)
hC = color.new(color.blue, 0)

// 分級:0=紅(該停) 1=黃(觀察) 2=綠(能用)
f_class(netP, ddP, pfFull, nFull, recPct) =>
    rdd = ddP > 0 ? netP / ddP : 0.0
    bool qual = nFull >= minTr and pfFull >= minPF and rdd >= minRDD and pfFull >= pfGreen and ddP <= ddCap
    int cls = 0
    if not qual
        cls := 0
    else if na(recPct)
        cls := 1
    else if recPct < redPct
        cls := 0
    else if recPct < freshMin
        cls := 1
    else
        cls := 2
    cls

f_cell(row, sym, netP, ddP, pfFull, nFull, recRet, recPct, regn) =>
    parts = str.split(sym, ":")
    short = array.size(parts) > 1 ? array.get(parts, array.size(parts) - 1) : sym
    rdd   = ddP > 0 ? netP / ddP : 0.0
    cls   = f_class(netP, ddP, pfFull, nFull, recPct)
    lamp  = nFull == 0 ? "⚪" : cls == 2 ? "🟢" : cls == 1 ? "🟡" : "🔴"
    lampC = nFull == 0 ? kC : cls == 2 ? gC : cls == 1 ? yC : rC
    reg   = regn == 1 ? "📈多頭" : regn == -1 ? "📉空頭" : "➖盤整"
    regC  = regn == 1 ? gC : regn == -1 ? rC : kC
    recTxt = na(recPct) ? "—" : str.tostring(recRet,"#")+"% P"+str.tostring(recPct,"#")
    recC   = na(recPct) ? kC : recPct>=freshMin ? gC : recPct>=redPct ? yC : rC
    table.cell(tb, 0, row, short, text_color=color.white, bgcolor=kC, text_size=size.normal)
    table.cell(tb, 1, row, lamp,  text_color=color.white, bgcolor=lampC, text_size=size.normal)
    table.cell(tb, 2, row, str.tostring(pfFull,"#.0"), text_color=color.white, bgcolor=pfFull>=pfGreen?gC:(pfFull>=minPF?yC:rC), text_size=size.small)
    table.cell(tb, 3, row, recTxt, text_color=color.white, bgcolor=recC, text_size=size.small)
    table.cell(tb, 4, row, str.tostring(rdd,"#.0")+" / DD"+str.tostring(ddP,"#")+"%", text_color=color.white, bgcolor=(rdd>=minRDD and ddP<=ddCap)?gC:rC, text_size=size.small)
    table.cell(tb, 5, row, reg, text_color=color.white, bgcolor=regC, text_size=size.small)

f_draw(row, sym, netP, ddP, pfFull, nFull, recRet, recPct, regn) =>
    int out = row
    if sym != "" and ((not greenOnly) or f_class(netP, ddP, pfFull, nFull, recPct) == 2)
        f_cell(row, sym, netP, ddP, pfFull, nFull, recRet, recPct, regn)
        out := row + 1
    out

if barstate.islast
    table.clear(tb, 0, 0, 5, 32)
    table.cell(tb, 0, 0, "標的", text_color=color.white, bgcolor=hC, text_size=size.normal)
    table.cell(tb, 1, 0, "燈",   text_color=color.white, bgcolor=hC, text_size=size.normal)
    table.cell(tb, 2, 0, "全PF", text_color=color.white, bgcolor=hC, text_size=size.small)
    table.cell(tb, 3, 0, "近半年(報酬·排名)", text_color=color.white, bgcolor=hC, text_size=size.small)
    table.cell(tb, 4, 0, "報酬/回撤·DD", text_color=color.white, bgcolor=hC, text_size=size.small)
    table.cell(tb, 5, 0, "現在", text_color=color.white, bgcolor=hC, text_size=size.small)
    int rr = 1
    rr := f_draw(rr, s1,  n1,  d1,  f1,  nf1,  rr1,  rp1,  r1)
    rr := f_draw(rr, s2,  n2,  d2,  f2,  nf2,  rr2,  rp2,  r2)
    rr := f_draw(rr, s3,  n3,  d3,  f3,  nf3,  rr3,  rp3,  r3)
    rr := f_draw(rr, s4,  n4,  d4,  f4,  nf4,  rr4,  rp4,  r4)
    rr := f_draw(rr, s5,  n5,  d5,  f5,  nf5,  rr5,  rp5,  r5)
    rr := f_draw(rr, s6,  n6,  d6,  f6,  nf6,  rr6,  rp6,  r6)
    rr := f_draw(rr, s7,  n7,  d7,  f7,  nf7,  rr7,  rp7,  r7)
    rr := f_draw(rr, s8,  n8,  d8,  f8,  nf8,  rr8,  rp8,  r8)
    rr := f_draw(rr, s9,  n9,  d9,  f9,  nf9,  rr9,  rp9,  r9)
    rr := f_draw(rr, s10, n10, d10, f10, nf10, rr10, rp10, r10)
    rr := f_draw(rr, s11, n11, d11, f11, nf11, rr11, rp11, r11)
    rr := f_draw(rr, s12, n12, d12, f12, nf12, rr12, rp12, r12)
    rr := f_draw(rr, s13, n13, d13, f13, nf13, rr13, rp13, r13)
    rr := f_draw(rr, s14, n14, d14, f14, nf14, rr14, rp14, r14)
    rr := f_draw(rr, s15, n15, d15, f15, nf15, rr15, rp15, r15)
    rr := f_draw(rr, s16, n16, d16, f16, nf16, rr16, rp16, r16)
    rr := f_draw(rr, s17, n17, d17, f17, nf17, rr17, rp17, r17)
    rr := f_draw(rr, s18, n18, d18, f18, nf18, rr18, rp18, r18)
    rr := f_draw(rr, s19, n19, d19, f19, nf19, rr19, rp19, r19)
    rr := f_draw(rr, s20, n20, d20, f20, nf20, rr20, rp20, r20)
    rr := f_draw(rr, s21, n21, d21, f21, nf21, rr21, rp21, r21)
    rr := f_draw(rr, s22, n22, d22, f22, nf22, rr22, rp22, r22)
    rr := f_draw(rr, s23, n23, d23, f23, nf23, rr23, rp23, r23)
    rr := f_draw(rr, s24, n24, d24, f24, nf24, rr24, rp24, r24)
    rr := f_draw(rr, s25, n25, d25, f25, nf25, rr25, rp25, r25)
    rr := f_draw(rr, s26, n26, d26, f26, nf26, rr26, rp26, r26)
    rr := f_draw(rr, s27, n27, d27, f27, nf27, rr27, rp27, r27)
    rr := f_draw(rr, s28, n28, d28, f28, nf28, rr28, rp28, r28)
    rr := f_draw(rr, s29, n29, d29, f29, nf29, rr29, rp29, r29)
    rr := f_draw(rr, s30, n30, d30, f30, nf30, rr30, rp30, r30)
    if rr == 1
        table.cell(tb, 0, 1, "(目前無綠燈)", text_color=color.white, bgcolor=kC, text_size=size.normal)
        rr := 2
    table.cell(tb, 0, rr, "綠燈 "+str.tostring(rr-1)+" 檔", text_color=color.white, bgcolor=kC, text_size=size.small)
    table.cell(tb, 2, rr, "綠=PF≥"+str.tostring(pfGreen,"#.0")+"·回撤≤"+str.tostring(ddCap,"#")+"%·近半年報酬排名≥"+str.tostring(freshMin,"#")+"(低於"+str.tostring(redPct,"#")+"=衰退紅)", text_color=color.white, bgcolor=kC, text_size=size.small)
    table.merge_cells(tb, 2, rr, 5, rr)
