//@version=5
// 多標的「逐年走查 Walk-Forward」綠燈總表(30 檔)— Claude
// 掛在 BTC 日線圖。幣前10 + 美股前10 + 台股前10,每檔用同一套寫死規則跑全歷史,
// 並把每一年單獨拿出來看(walk-forward):近K年有幾年該年 PF≥1 + 是否連2年虧。
// 綠燈 = 歷史有效 且 近年逐年連續性沒壞 且 沒連2年虧。打開「只顯示綠燈」只剩可續用的。
//
// ⚠️ 很重:30 檔 = 跑 30 次回測,可能轉很久。卡住就把某類 10 格留白分批跑。
// ⚠️ 燈=這策略在這標的歷史有效+近年仍連續有效,不是叫你立刻進場。進場看主策略訊號。
indicator("逐年走查綠燈總表(30檔)— Claude", overlay=true)

boxLen   = 10
rvolLen  = 20
rvolMin  = 1.3
emaLen   = 200
atrLen   = 14
atrBuf   = 0.25
atrTrail = 3.5
riskPct  = 5.0
levCap   = 5.0
minStopP = 0.005
beATR    = 3.0
COMM     = 0.00055
INIT     = 1000000.0

minTr   = input.int(20,   "全期最低交易數",       group="判準")
minPF   = input.float(1.3,"全期最低 PF",          group="判準")
minRDD  = input.float(3.0,"全期最低 報酬/回撤",   group="判準")
K       = input.int(5,    "看最近幾年(逐年走查)", group="逐年走查")
yrPFok  = input.float(1.0,"該年算過關的最低 PF",  group="逐年走查")
consMin = input.float(0.6,"近K年至少幾成要過關",  group="逐年走查")
greenOnly = input.bool(true, "只顯示綠燈(關掉=全部都顯示)", group="顯示")
posI   = input.string("右上","表格位置", options=["右上","右下","左上","左下","中央"], group="顯示")
tpos = posI=="右下"?position.bottom_right : posI=="左上"?position.top_left : posI=="左下"?position.bottom_left : posI=="中央"?position.middle_center : position.top_right

gc = "加密前10大"
s1  = input.symbol("BINANCE:BTCUSDT",  "幣1",  group=gc)
s2  = input.symbol("BINANCE:ETHUSDT",  "幣2",  group=gc)
s3  = input.symbol("BINANCE:BNBUSDT",  "幣3",  group=gc)
s4  = input.symbol("BINANCE:SOLUSDT",  "幣4",  group=gc)
s5  = input.symbol("BINANCE:XRPUSDT",  "幣5",  group=gc)
s6  = input.symbol("BINANCE:ADAUSDT",  "幣6",  group=gc)
s7  = input.symbol("BINANCE:DOGEUSDT", "幣7",  group=gc)
s8  = input.symbol("BINANCE:AVAXUSDT", "幣8",  group=gc)
s9  = input.symbol("BINANCE:TRXUSDT",  "幣9",  group=gc)
s10 = input.symbol("BINANCE:LINKUSDT", "幣10", group=gc)
gu = "美股前10大"
s11 = input.symbol("NASDAQ:NVDA",  "美1",  group=gu)
s12 = input.symbol("NASDAQ:AAPL",  "美2",  group=gu)
s13 = input.symbol("NASDAQ:MSFT",  "美3",  group=gu)
s14 = input.symbol("NASDAQ:AMZN",  "美4",  group=gu)
s15 = input.symbol("NASDAQ:GOOGL", "美5",  group=gu)
s16 = input.symbol("NASDAQ:META",  "美6",  group=gu)
s17 = input.symbol("NASDAQ:TSLA",  "美7",  group=gu)
s18 = input.symbol("NASDAQ:AVGO",  "美8",  group=gu)
s19 = input.symbol("NASDAQ:AMD",   "美9",  group=gu)
s20 = input.symbol("NASDAQ:NFLX",  "美10", group=gu)
gt = "台股前10大"
s21 = input.symbol("TWSE:2330", "台1",  group=gt)
s22 = input.symbol("TWSE:2317", "台2",  group=gt)
s23 = input.symbol("TWSE:2454", "台3",  group=gt)
s24 = input.symbol("TWSE:2308", "台4",  group=gt)
s25 = input.symbol("TWSE:2382", "台5",  group=gt)
s26 = input.symbol("TWSE:2891", "台6",  group=gt)
s27 = input.symbol("TWSE:2412", "台7",  group=gt)
s28 = input.symbol("TWSE:2881", "台8",  group=gt)
s29 = input.symbol("TWSE:3711", "台9",  group=gt)
s30 = input.symbol("TWSE:2603", "台10", group=gt)

// ── 引擎:回傳 [報酬%, 回撤%, 全PF, 全筆, 近K年過關數, 近K年可評年數, 連2年虧(1/0), 現在多空] ──
f_eval() =>
    ema200 = ta.ema(close, emaLen)
    atr    = ta.atr(atrLen)
    vsma   = ta.sma(volume, rvolLen)
    rvol   = vsma > 0 ? volume / vsma : 0.0
    hh10   = ta.highest(high, boxLen)[1]
    ll10   = ta.lowest(low,  boxLen)[1]
    var float cash  = INIT
    var int   pos   = 0
    var float qty   = 0.0
    var float entry = 0.0
    var float pst   = 0.0
    var float atrE  = 0.0
    var float hh    = 0.0
    var float ll    = 0.0
    var bool  beArm = false
    var float etime = 0.0
    var float peak  = INIT
    var float maxdd = 0.0
    var float gpAll = 0.0
    var float glAll = 0.0
    var int   nAll  = 0
    var array<float> plArr = array.new_float(0)
    var array<float> etArr = array.new_float(0)
    if pos != 0 and not na(atr)
        float ex = na
        if pos > 0
            if low <= pst
                ex := open < pst ? open : pst
        else
            if high >= pst
                ex := open > pst ? open : pst
        if not na(ex)
            float pnl = pos > 0 ? (ex - entry) * qty : (entry - ex) * qty
            pnl := pnl - COMM * qty * (entry + ex)
            cash := cash + pnl
            nAll  := nAll + 1
            gpAll := gpAll + (pnl > 0 ? pnl : 0.0)
            glAll := glAll + (pnl < 0 ? -pnl : 0.0)
            array.push(plArr, pnl)
            array.push(etArr, etime)
            pos := 0
        else
            if pos > 0
                hh := math.max(hh, high)
                if not beArm and hh >= entry + beATR * atrE
                    beArm := true
                pst := math.max(pst, hh - atrTrail * atr)
                if beArm
                    pst := math.max(pst, entry)
            else
                ll := math.min(ll, low)
                if not beArm and ll <= entry - beATR * atrE
                    beArm := true
                pst := math.min(pst, ll + atrTrail * atr)
                if beArm
                    pst := math.min(pst, entry)
    bool canTrade = pos == 0 and bar_index > emaLen and not na(atr) and not na(ema200[20]) and not na(hh10)
    if canTrade
        bool bear   = ema200 < ema200[20]
        bool longS  = close > hh10 + atrBuf * atr and rvol >= rvolMin and close > ema200
        bool shortS = bear and close < ll10 - atrBuf * atr and rvol >= rvolMin and close < ema200
        if longS
            float d = math.max((close - low[1]) / close, minStopP)
            qty   := math.min(cash * riskPct / 100.0 / (d * close), levCap * cash / close)
            pos   := 1
            entry := close
            pst   := close - d * close
            atrE  := atr
            hh    := high
            beArm := false
            etime := time
        else if shortS
            float d = math.max((high[1] - close) / close, minStopP)
            qty   := math.min(cash * riskPct / 100.0 / (d * close), levCap * cash / close)
            pos   := -1
            entry := close
            pst   := close + d * close
            atrE  := atr
            ll    := low
            beArm := false
            etime := time
    float mtm = cash + (pos == 0 ? 0.0 : pos > 0 ? (close - entry) * qty : (entry - close) * qty)
    peak  := math.max(peak, mtm)
    maxdd := math.max(maxdd, (peak - mtm) / peak * 100.0)
    float netP   = (cash - INIT) / INIT * 100.0
    float pfFull = glAll > 0 ? gpAll / glAll : (gpAll > 0 ? 99.0 : 0.0)
    // 逐年走查:只在最後一根算
    int passRec = 0
    int availRec = 0
    bool l2f = false
    if barstate.islast and array.size(plArr) > 0
        int sz = array.size(plArr)
        int minY = 9999
        int maxY = 0
        for i = 0 to sz - 1
            int yy = year(int(array.get(etArr, i)))
            minY := math.min(minY, yy)
            maxY := math.max(maxY, yy)
        bool lastFail = false
        bool prevFail = false
        for y = minY to maxY
            float ygp = 0.0
            float ygl = 0.0
            int   ycn = 0
            for i = 0 to sz - 1
                if year(int(array.get(etArr, i))) == y
                    float p = array.get(plArr, i)
                    ycn := ycn + 1
                    ygp := ygp + (p > 0 ? p : 0.0)
                    ygl := ygl + (p < 0 ? -p : 0.0)
            float ypf = ygl > 0 ? ygp / ygl : (ygp > 0 ? 99.0 : 0.0)
            bool yok = ycn > 0 and ypf >= yrPFok
            if y > maxY - K and ycn > 0
                availRec := availRec + 1
                if yok
                    passRec := passRec + 1
            if y > maxY - 2 and ycn > 0
                prevFail := lastFail
                lastFail := not yok
        l2f := prevFail and lastFail
    int regn = na(ema200) or na(ema200[20]) ? 0 : (ema200 > ema200[20] and close > ema200 ? 1 : (ema200 < ema200[20] and close < ema200 ? -1 : 0))
    [netP, maxdd, pfFull, nAll, passRec, availRec, l2f ? 1 : 0, regn]

f_req(sym) =>
    request.security(sym, "1D", f_eval(), gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)

[n1,d1,f1,nf1,pr1,av1,l1,r1]    = f_req(s1)
[n2,d2,f2,nf2,pr2,av2,l2,r2]    = f_req(s2)
[n3,d3,f3,nf3,pr3,av3,l3,r3]    = f_req(s3)
[n4,d4,f4,nf4,pr4,av4,l4,r4]    = f_req(s4)
[n5,d5,f5,nf5,pr5,av5,l5,r5]    = f_req(s5)
[n6,d6,f6,nf6,pr6,av6,l6,r6]    = f_req(s6)
[n7,d7,f7,nf7,pr7,av7,l7,r7]    = f_req(s7)
[n8,d8,f8,nf8,pr8,av8,l8,r8]    = f_req(s8)
[n9,d9,f9,nf9,pr9,av9,l9,r9]    = f_req(s9)
[n10,d10,f10,nf10,pr10,av10,l10,r10] = f_req(s10)
[n11,d11,f11,nf11,pr11,av11,l11,r11] = f_req(s11)
[n12,d12,f12,nf12,pr12,av12,l12,r12] = f_req(s12)
[n13,d13,f13,nf13,pr13,av13,l13,r13] = f_req(s13)
[n14,d14,f14,nf14,pr14,av14,l14,r14] = f_req(s14)
[n15,d15,f15,nf15,pr15,av15,l15,r15] = f_req(s15)
[n16,d16,f16,nf16,pr16,av16,l16,r16] = f_req(s16)
[n17,d17,f17,nf17,pr17,av17,l17,r17] = f_req(s17)
[n18,d18,f18,nf18,pr18,av18,l18,r18] = f_req(s18)
[n19,d19,f19,nf19,pr19,av19,l19,r19] = f_req(s19)
[n20,d20,f20,nf20,pr20,av20,l20,r20] = f_req(s20)
[n21,d21,f21,nf21,pr21,av21,l21,r21] = f_req(s21)
[n22,d22,f22,nf22,pr22,av22,l22,r22] = f_req(s22)
[n23,d23,f23,nf23,pr23,av23,l23,r23] = f_req(s23)
[n24,d24,f24,nf24,pr24,av24,l24,r24] = f_req(s24)
[n25,d25,f25,nf25,pr25,av25,l25,r25] = f_req(s25)
[n26,d26,f26,nf26,pr26,av26,l26,r26] = f_req(s26)
[n27,d27,f27,nf27,pr27,av27,l27,r27] = f_req(s27)
[n28,d28,f28,nf28,pr28,av28,l28,r28] = f_req(s28)
[n29,d29,f29,nf29,pr29,av29,l29,r29] = f_req(s29)
[n30,d30,f30,nf30,pr30,av30,l30,r30] = f_req(s30)

var table tb = table.new(tpos, 6, 33, border_width=1, frame_width=1, frame_color=color.gray)
gC = color.new(color.green, 0)
yC = color.new(color.orange, 0)
rC = color.new(color.red, 0)
kC = color.new(color.gray, 20)
hC = color.new(color.blue, 0)

// 分級:0=紅(該停) 1=黃(觀察) 2=綠(續用)
f_class(netP, ddP, pfFull, nFull, passRec, availRec, l2f) =>
    rdd = ddP > 0 ? netP / ddP : 0.0
    bool baseOK = nFull >= minTr and pfFull >= minPF and rdd >= minRDD
    bool consOK = availRec > 0 and passRec * 1.0 / availRec >= consMin
    bool dead   = l2f == 1
    int cls = (baseOK and consOK and not dead) ? 2 : ((baseOK and not dead) ? 1 : 0)
    cls

f_cell(row, sym, netP, ddP, pfFull, nFull, passRec, availRec, l2f, regn) =>
    parts = str.split(sym, ":")
    short = array.size(parts) > 1 ? array.get(parts, array.size(parts) - 1) : sym
    rdd   = ddP > 0 ? netP / ddP : 0.0
    cls   = f_class(netP, ddP, pfFull, nFull, passRec, availRec, l2f)
    lamp  = nFull == 0 ? "⚪" : cls == 2 ? "🟢" : cls == 1 ? "🟡" : "🔴"
    lampC = nFull == 0 ? kC : cls == 2 ? gC : cls == 1 ? yC : rC
    reg   = regn == 1 ? "📈多頭" : regn == -1 ? "📉空頭" : "➖盤整"
    regC  = regn == 1 ? gC : regn == -1 ? rC : kC
    consTxt = str.tostring(passRec) + "/" + str.tostring(availRec) + (l2f == 1 ? " 連2虧" : "")
    consC   = l2f == 1 ? rC : (availRec > 0 and passRec * 1.0 / availRec >= consMin ? gC : yC)
    table.cell(tb, 0, row, short, text_color=color.white, bgcolor=kC, text_size=size.normal)
    table.cell(tb, 1, row, lamp,  text_color=color.white, bgcolor=lampC, text_size=size.normal)
    table.cell(tb, 2, row, str.tostring(pfFull,"#.0"), text_color=color.white, bgcolor=pfFull>=minPF?gC:rC, text_size=size.small)
    table.cell(tb, 3, row, consTxt, text_color=color.white, bgcolor=consC, text_size=size.small)
    table.cell(tb, 4, row, str.tostring(rdd,"#.0"), text_color=color.white, bgcolor=rdd>=minRDD?gC:rC, text_size=size.small)
    table.cell(tb, 5, row, reg, text_color=color.white, bgcolor=regC, text_size=size.small)

f_draw(row, sym, netP, ddP, pfFull, nFull, passRec, availRec, l2f, regn) =>
    int out = row
    if sym != "" and ((not greenOnly) or f_class(netP, ddP, pfFull, nFull, passRec, availRec, l2f) == 2)
        f_cell(row, sym, netP, ddP, pfFull, nFull, passRec, availRec, l2f, regn)
        out := row + 1
    out

if barstate.islast
    table.clear(tb, 0, 0, 5, 32)
    table.cell(tb, 0, 0, "標的", text_color=color.white, bgcolor=hC, text_size=size.normal)
    table.cell(tb, 1, 0, "燈",   text_color=color.white, bgcolor=hC, text_size=size.normal)
    table.cell(tb, 2, 0, "全PF", text_color=color.white, bgcolor=hC, text_size=size.small)
    table.cell(tb, 3, 0, "近K年過", text_color=color.white, bgcolor=hC, text_size=size.small)
    table.cell(tb, 4, 0, "報酬/回撤", text_color=color.white, bgcolor=hC, text_size=size.small)
    table.cell(tb, 5, 0, "現在", text_color=color.white, bgcolor=hC, text_size=size.small)
    int rr = 1
    rr := f_draw(rr, s1,  n1,  d1,  f1,  nf1,  pr1,  av1,  l1,  r1)
    rr := f_draw(rr, s2,  n2,  d2,  f2,  nf2,  pr2,  av2,  l2,  r2)
    rr := f_draw(rr, s3,  n3,  d3,  f3,  nf3,  pr3,  av3,  l3,  r3)
    rr := f_draw(rr, s4,  n4,  d4,  f4,  nf4,  pr4,  av4,  l4,  r4)
    rr := f_draw(rr, s5,  n5,  d5,  f5,  nf5,  pr5,  av5,  l5,  r5)
    rr := f_draw(rr, s6,  n6,  d6,  f6,  nf6,  pr6,  av6,  l6,  r6)
    rr := f_draw(rr, s7,  n7,  d7,  f7,  nf7,  pr7,  av7,  l7,  r7)
    rr := f_draw(rr, s8,  n8,  d8,  f8,  nf8,  pr8,  av8,  l8,  r8)
    rr := f_draw(rr, s9,  n9,  d9,  f9,  nf9,  pr9,  av9,  l9,  r9)
    rr := f_draw(rr, s10, n10, d10, f10, nf10, pr10, av10, l10, r10)
    rr := f_draw(rr, s11, n11, d11, f11, nf11, pr11, av11, l11, r11)
    rr := f_draw(rr, s12, n12, d12, f12, nf12, pr12, av12, l12, r12)
    rr := f_draw(rr, s13, n13, d13, f13, nf13, pr13, av13, l13, r13)
    rr := f_draw(rr, s14, n14, d14, f14, nf14, pr14, av14, l14, r14)
    rr := f_draw(rr, s15, n15, d15, f15, nf15, pr15, av15, l15, r15)
    rr := f_draw(rr, s16, n16, d16, f16, nf16, pr16, av16, l16, r16)
    rr := f_draw(rr, s17, n17, d17, f17, nf17, pr17, av17, l17, r17)
    rr := f_draw(rr, s18, n18, d18, f18, nf18, pr18, av18, l18, r18)
    rr := f_draw(rr, s19, n19, d19, f19, nf19, pr19, av19, l19, r19)
    rr := f_draw(rr, s20, n20, d20, f20, nf20, pr20, av20, l20, r20)
    rr := f_draw(rr, s21, n21, d21, f21, nf21, pr21, av21, l21, r21)
    rr := f_draw(rr, s22, n22, d22, f22, nf22, pr22, av22, l22, r22)
    rr := f_draw(rr, s23, n23, d23, f23, nf23, pr23, av23, l23, r23)
    rr := f_draw(rr, s24, n24, d24, f24, nf24, pr24, av24, l24, r24)
    rr := f_draw(rr, s25, n25, d25, f25, nf25, pr25, av25, l25, r25)
    rr := f_draw(rr, s26, n26, d26, f26, nf26, pr26, av26, l26, r26)
    rr := f_draw(rr, s27, n27, d27, f27, nf27, pr27, av27, l27, r27)
    rr := f_draw(rr, s28, n28, d28, f28, nf28, pr28, av28, l28, r28)
    rr := f_draw(rr, s29, n29, d29, f29, nf29, pr29, av29, l29, r29)
    rr := f_draw(rr, s30, n30, d30, f30, nf30, pr30, av30, l30, r30)
    if rr == 1
        table.cell(tb, 0, 1, "(目前無綠燈)", text_color=color.white, bgcolor=kC, text_size=size.normal)
        rr := 2
    table.cell(tb, 0, rr, "綠燈 "+str.tostring(rr-1)+" 檔", text_color=color.white, bgcolor=kC, text_size=size.small)
    table.cell(tb, 2, rr, "綠=歷史過關+近"+str.tostring(K)+"年≥"+str.tostring(consMin*100,"#")+"%年數過關+沒連2年虧(關開關看全部)", text_color=color.white, bgcolor=kC, text_size=size.small)
    table.merge_cells(tb, 2, rr, 5, rr)
