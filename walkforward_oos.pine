//@version=5
// 錨定式前進測試 OOS · 增益(lift)版 — Claude
// 掛任何標的日線圖。一年一年往前滾,每年用「滾動近N年」的成績當『事前判定』(不偷看未來、也不被古早資料拖死):
//   判定『可做』= 近N年滾動 PF ≥ 門檻;事後看『該年』真的賺不賺。
// 關鍵看「增益」:可做年的勝率 有沒有 明顯高過 不做年的勝率 與 基準勝率。
//   有明顯高 → 判定真的有鑑別力(會挑);差不多 → 判定沒用(只是反映標的本來好壞)。
// 修正:該年% 用『該年初的權益』當分母(不再用固定本金,避免後期數字爆掉失真)。
indicator("錨定前進 OOS · 增益版 — Claude", overlay=true)

boxLen   = 10
rvolLen  = 20
rvolMin  = 1.3
emaLen   = 200
atrLen   = 14
atrBuf   = 0.25
atrTrail = 3.5
riskPct  = 5.0
levCap   = 5.0
minStopP = 0.005
beATR    = 3.0
COMM     = 0.00055
INIT     = 1000000.0

lookYrs = input.int(3,    "事前判定:滾動近幾年", group="判定")
qPF     = input.float(1.5,"事前判定『可做』:滾動 PF ≥", group="判定")
qMinN   = input.int(10,   "事前判定:滾動窗最低交易數", group="判定")
okPF    = input.float(1.3,"事後該年算『成功』:該年 PF ≥", group="判定")
liftMin = input.float(15, "判定可信:增益(可做-不做)需 ≥ 幾個百分點", group="判定")
posI    = input.string("右上","表格位置", options=["右上","右下","左上","左下","中央"], group="顯示")
tpos = posI=="右下"?position.bottom_right : posI=="左上"?position.top_left : posI=="左下"?position.bottom_left : posI=="中央"?position.middle_center : position.top_right

ema200 = ta.ema(close, emaLen)
atr    = ta.atr(atrLen)
vsma   = ta.sma(volume, rvolLen)
rvol   = vsma > 0 ? volume / vsma : 0.0
hh10   = ta.highest(high, boxLen)[1]
ll10   = ta.lowest(low,  boxLen)[1]

var float cash  = INIT
var int   pos   = 0
var float qty   = 0.0
var float entry = 0.0
var float pst   = 0.0
var float atrE  = 0.0
var float hh    = 0.0
var float ll    = 0.0
var bool  beArm = false
var float etime = 0.0
var array<float> plArr = array.new_float(0)
var array<float> etArr = array.new_float(0)

if pos != 0 and not na(atr)
    float ex = na
    if pos > 0
        if low <= pst
            ex := open < pst ? open : pst
    else
        if high >= pst
            ex := open > pst ? open : pst
    if not na(ex)
        float pnl = pos > 0 ? (ex - entry) * qty : (entry - ex) * qty
        pnl := pnl - COMM * qty * (entry + ex)
        cash := cash + pnl
        array.push(plArr, pnl)
        array.push(etArr, etime)
        pos := 0
    else
        if pos > 0
            hh := math.max(hh, high)
            if not beArm and hh >= entry + beATR * atrE
                beArm := true
            pst := math.max(pst, hh - atrTrail * atr)
            if beArm
                pst := math.max(pst, entry)
        else
            ll := math.min(ll, low)
            if not beArm and ll <= entry - beATR * atrE
                beArm := true
            pst := math.min(pst, ll + atrTrail * atr)
            if beArm
                pst := math.min(pst, entry)

bool canTrade = pos == 0 and bar_index > emaLen and not na(atr) and not na(ema200[20]) and not na(hh10)
if canTrade
    bool bear   = ema200 < ema200[20]
    bool longS  = close > hh10 + atrBuf * atr and rvol >= rvolMin and close > ema200
    bool shortS = bear and close < ll10 - atrBuf * atr and rvol >= rvolMin and close < ema200
    if longS
        float d = math.max((close - low[1]) / close, minStopP)
        qty   := math.min(cash * riskPct / 100.0 / (d * close), levCap * cash / close)
        pos   := 1
        entry := close
        pst   := close - d * close
        atrE  := atr
        hh    := high
        beArm := false
        etime := time
    else if shortS
        float d = math.max((high[1] - close) / close, minStopP)
        qty   := math.min(cash * riskPct / 100.0 / (d * close), levCap * cash / close)
        pos   := -1
        entry := close
        pst   := close + d * close
        atrE  := atr
        ll    := low
        beArm := false
        etime := time

plot(ema200, "EMA200", color.new(color.orange, 0))

var table tb = table.new(tpos, 5, 40, border_width=1, frame_width=1, frame_color=color.gray)
gC = color.new(color.green, 0)
rC = color.new(color.red, 0)
kC = color.new(color.gray, 20)
hC = color.new(color.blue, 0)

if barstate.islast
    table.clear(tb, 0, 0, 4, 39)
    table.cell(tb, 0, 0, "年",        text_color=color.white, bgcolor=hC, text_size=size.small)
    table.cell(tb, 1, 0, "近"+str.tostring(lookYrs)+"年PF(判定)", text_color=color.white, bgcolor=hC, text_size=size.small)
    table.cell(tb, 2, 0, "該年PF(事後)", text_color=color.white, bgcolor=hC, text_size=size.small)
    table.cell(tb, 3, 0, "該年%",       text_color=color.white, bgcolor=hC, text_size=size.small)
    table.cell(tb, 4, 0, "吻合",        text_color=color.white, bgcolor=hC, text_size=size.small)
    int sz = array.size(plArr)
    int minY = 9999
    int maxY = 0
    if sz > 0
        for i = 0 to sz - 1
            int yy = year(int(array.get(etArr, i)))
            minY := math.min(minY, yy)
            maxY := math.max(maxY, yy)
    int row = 1
    int nEval = 0
    int nWin  = 0
    int nQ    = 0
    int nQWin = 0
    int nU    = 0
    int nUWin = 0
    if sz > 0
        for Y = minY to maxY
            float rGp = 0.0
            float rGl = 0.0
            int   rN  = 0
            float yGp = 0.0
            float yGl = 0.0
            int   yN  = 0
            float yNet = 0.0
            float beforeNet = 0.0
            for i = 0 to sz - 1
                int yy = year(int(array.get(etArr, i)))
                float p = array.get(plArr, i)
                if yy < Y
                    beforeNet := beforeNet + p
                if yy >= Y - lookYrs and yy <= Y - 1
                    rN  := rN + 1
                    rGp := rGp + (p > 0 ? p : 0.0)
                    rGl := rGl + (p < 0 ? -p : 0.0)
                if yy == Y
                    yN   := yN + 1
                    yNet := yNet + p
                    yGp  := yGp + (p > 0 ? p : 0.0)
                    yGl  := yGl + (p < 0 ? -p : 0.0)
            if rN >= qMinN and yN > 0
                float rPF = rGl > 0 ? rGp / rGl : (rGp > 0 ? 99.0 : 0.0)
                float yPF = yGl > 0 ? yGp / yGl : (yGp > 0 ? 99.0 : 0.0)
                float startEq = INIT + beforeNet
                float yRet = startEq != 0 ? yNet / startEq * 100.0 : na
                bool qualified = rPF >= qPF
                bool yearOK    = yPF >= okPF
                bool match     = qualified == yearOK
                nEval := nEval + 1
                if yearOK
                    nWin := nWin + 1
                if qualified
                    nQ := nQ + 1
                    if yearOK
                        nQWin := nQWin + 1
                else
                    nU := nU + 1
                    if yearOK
                        nUWin := nUWin + 1
                table.cell(tb, 0, row, str.tostring(Y), text_color=color.white, bgcolor=kC, text_size=size.small)
                table.cell(tb, 1, row, str.tostring(rPF,"#.0")+(qualified?" 可做":" 不做"), text_color=color.white, bgcolor=qualified?gC:rC, text_size=size.small)
                table.cell(tb, 2, row, str.tostring(yPF,"#.0")+(yearOK?" 賺":" 虧"),       text_color=color.white, bgcolor=yearOK?gC:rC, text_size=size.small)
                table.cell(tb, 3, row, na(yRet)?"—":str.tostring(yRet,"#")+"%", text_color=color.white, bgcolor=(not na(yRet) and yRet>=0)?gC:rC, text_size=size.small)
                table.cell(tb, 4, row, match?"✅":"❌", text_color=color.white, bgcolor=match?gC:rC, text_size=size.small)
                row := row + 1
    float qWin = nQ > 0 ? nQWin * 100.0 / nQ : na
    float uWin = nU > 0 ? nUWin * 100.0 / nU : na
    float base = nEval > 0 ? nWin * 100.0 / nEval : na
    float lift = (not na(qWin) and not na(uWin)) ? qWin - uWin : na
    bool enough = nQ >= 3 and nU >= 3
    bool trust  = enough and not na(lift) and lift >= liftMin
    table.cell(tb, 0, row, "可做年勝率", text_color=color.white, bgcolor=kC, text_size=size.small)
    table.cell(tb, 1, row, na(qWin)?"—":str.tostring(qWin,"#")+"% ("+str.tostring(nQ)+")", text_color=color.white, bgcolor=kC, text_size=size.small)
    table.cell(tb, 2, row, "不做年勝率", text_color=color.white, bgcolor=kC, text_size=size.small)
    table.cell(tb, 3, row, na(uWin)?"—":str.tostring(uWin,"#")+"% ("+str.tostring(nU)+")", text_color=color.white, bgcolor=kC, text_size=size.small)
    table.cell(tb, 4, row, "", bgcolor=kC)
    row := row + 1
    table.cell(tb, 0, row, "基準勝率", text_color=color.white, bgcolor=kC, text_size=size.small)
    table.cell(tb, 1, row, na(base)?"—":str.tostring(base,"#")+"%", text_color=color.white, bgcolor=kC, text_size=size.small)
    table.cell(tb, 2, row, "增益(可做-不做)", text_color=color.white, bgcolor=kC, text_size=size.small)
    table.cell(tb, 3, row, na(lift)?"—":str.tostring(lift,"#")+"pp", text_color=color.white, bgcolor=na(lift)?kC:(lift>=liftMin?gC:rC), text_size=size.small)
    table.cell(tb, 4, row, "", bgcolor=kC)
    row := row + 1
    string vtxt = not enough ? ("資料不足 可做"+str.tostring(nQ)+"/不做"+str.tostring(nU)) : (trust ? "✅ 判定有鑑別力" : "⚠️ 判定沒鑑別力")
    table.cell(tb, 0, row, "驗證可信?", text_color=color.white, bgcolor=hC, text_size=size.normal)
    table.cell(tb, 1, row, vtxt, text_color=color.white, bgcolor=not enough?kC:(trust?gC:rC), text_size=size.normal)
    table.merge_cells(tb, 1, row, 4, row)
